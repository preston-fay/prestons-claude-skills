#!/usr/bin/env bash
# Skills Health Check and Validation Script
# Usage: .skillsrc [--check|--list|--validate <skill-id>]

set -e

SKILLS_DIR="$HOME/.claude/skills"
INDEX_FILE="$SKILLS_DIR/skills-index.yaml"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if skills directory exists
if [[ ! -d "$SKILLS_DIR" ]]; then
    echo -e "${RED}✗ Skills directory not found: $SKILLS_DIR${NC}"
    exit 1
fi

# Function to list all skills
list_skills() {
    echo -e "${BLUE}📚 Available Skills:${NC}"
    echo ""
    for dir in "$SKILLS_DIR"/*/ ; do
        if [[ -d "$dir" ]]; then
            skill_id=$(basename "$dir")
            if [[ "$skill_id" != "."* ]]; then  # Skip hidden dirs
                echo "  - $skill_id"
            fi
        fi
    done
}

# Function to validate a single skill
validate_skill() {
    local skill_id="$1"
    local skill_dir="$SKILLS_DIR/$skill_id"
    local skill_md="$skill_dir/SKILL.md"
    local errors=0
    local warnings=0

    echo -e "${BLUE}Validating: $skill_id${NC}"

    # Check if directory exists
    if [[ ! -d "$skill_dir" ]]; then
        echo -e "  ${RED}✗ Directory not found${NC}"
        return 1
    fi

    # Check if SKILL.md exists
    if [[ ! -f "$skill_md" ]]; then
        echo -e "  ${RED}✗ SKILL.md not found${NC}"
        return 1
    fi

    # Check for required sections
    local required_sections=("Purpose" "When to Use" "Usage")
    for section in "${required_sections[@]}"; do
        if ! grep -q "## $section" "$skill_md" && ! grep -q "# $section" "$skill_md"; then
            echo -e "  ${YELLOW}⚠ Missing section: $section${NC}"
            ((warnings++))
        fi
    done

    # Check for examples
    if ! grep -qi "example" "$skill_md" && ! grep -qi "usage" "$skill_md"; then
        echo -e "  ${YELLOW}⚠ No examples found${NC}"
        ((warnings++))
    fi

    # Check for command invocation
    if ! grep -q "/[a-z-]" "$skill_md"; then
        echo -e "  ${YELLOW}⚠ No command invocation found (e.g., /skill-name)${NC}"
        ((warnings++))
    fi

    # Report status
    if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
        echo -e "  ${GREEN}✓ All checks passed${NC}"
        return 0
    elif [[ $errors -eq 0 ]]; then
        echo -e "  ${YELLOW}⚠ Passed with $warnings warnings${NC}"
        return 0
    else
        echo -e "  ${RED}✗ Failed with $errors errors${NC}"
        return 1
    fi
}

# Function to check all skills
check_all_skills() {
    echo -e "${BLUE}=== Skills Health Check ===${NC}"
    echo ""

    local total=0
    local passed=0
    local failed=0
    local no_skill_md=0

    for dir in "$SKILLS_DIR"/*/ ; do
        if [[ -d "$dir" ]]; then
            skill_id=$(basename "$dir")

            # Skip hidden directories and special files
            if [[ "$skill_id" == "."* ]] || [[ "$skill_id" == "MY_SKILLS.md" ]]; then
                continue
            fi

            ((total++))

            if [[ ! -f "$dir/SKILL.md" ]]; then
                echo -e "${RED}✗${NC} $skill_id - No SKILL.md"
                ((no_skill_md++))
                ((failed++))
            else
                if validate_skill "$skill_id" >/dev/null 2>&1; then
                    echo -e "${GREEN}✓${NC} $skill_id"
                    ((passed++))
                else
                    echo -e "${YELLOW}⚠${NC} $skill_id - Has warnings"
                    ((passed++))
                fi
            fi
        fi
    done

    echo ""
    echo -e "${BLUE}=== Summary ===${NC}"
    echo -e "Total skills:        $total"
    echo -e "${GREEN}Passed:              $passed${NC}"
    echo -e "${RED}Missing SKILL.md:    $no_skill_md${NC}"
    echo ""

    if [[ $no_skill_md -eq 0 ]]; then
        echo -e "${GREEN}✅ All skills are healthy!${NC}"
        return 0
    else
        echo -e "${YELLOW}⚠ Some skills need attention${NC}"
        return 1
    fi
}

# Function to show usage
show_usage() {
    echo "Usage: .skillsrc [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  --check              Validate all skills"
    echo "  --list               List all available skills"
    echo "  --validate <skill>   Validate a specific skill"
    echo "  --help               Show this help message"
    echo ""
    echo "Examples:"
    echo "  .skillsrc --check"
    echo "  .skillsrc --list"
    echo "  .skillsrc --validate hypothesis-tree"
}

# Main script logic
case "${1:-}" in
    --check)
        check_all_skills
        ;;
    --list)
        list_skills
        ;;
    --validate)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: skill-id required${NC}"
            echo "Usage: .skillsrc --validate <skill-id>"
            exit 1
        fi
        validate_skill "$2"
        ;;
    --help)
        show_usage
        ;;
    "")
        # No arguments, default to check
        check_all_skills
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_usage
        exit 1
        ;;
esac
